/* ============================================
   PASIFIQ STORE — Premium CSS Design System
   Aesthetic: Refined Coastal Luxury
   ============================================ */

:root {
  /* Core Brand Colors */
  --brand-navy: #0f1f3d;
  --brand-ocean: #1e4d8c;
  --brand-teal: #0891b2;
  --brand-teal-light: #67e8f9;
  --brand-coral: #f97316;
  --brand-sand: #f5f0e8;
  
  /* Theme-aware Colors (Light Mode Default) */
  --bg-body: #ffffff;
  --bg-surface: #f9fafb;
  --bg-card: #ffffff;
  --bg-nav: rgba(255, 255, 255, 0.95);
  --border: #e5e7eb;
  --text-main: #111827;
  --text-muted: #6b7280;
  --text-inverse: #ffffff;
  --shadow-color: rgba(15, 31, 61, 0.1);

  /* Shared values */
  --radius-sm: 6px;
  --radius: 12px;
  --radius-lg: 20px;
  --radius-xl: 28px;
  --font-display: 'Playfair Display', Georgia, serif;
  --font-body: 'DM Sans', system-ui, sans-serif;
  --transition: 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  --success: #059669;
  --error: #dc2626;
  --warning: #d97706;
  --gold: #d4a017;

  /* Shadow Design System */
  --shadow-sm: 0 1px 2px var(--shadow-color);
  --shadow: 0 4px 6px -1px var(--shadow-color), 0 2px 4px -1px var(--shadow-color);
  --shadow-md: 0 10px 15px -3px var(--shadow-color), 0 4px 6px -2px var(--shadow-color);
  --shadow-lg: 0 20px 25px -5px var(--shadow-color), 0 10px 10px -5px var(--shadow-color);
  --shadow-xl: 0 25px 50px -12px var(--shadow-color);

  /* Legacy Mappings */
  --navy: var(--brand-navy);
  --ocean: var(--brand-ocean);
  --teal: var(--brand-teal);
  --coral: var(--brand-coral);
  --sand: var(--brand-sand);
}

[data-theme="dark"] {
  --bg-body: #0a0f1d;
  --bg-surface: #111827;
  --bg-card: #1a2333;
  --bg-nav: rgba(10, 15, 29, 0.95);
  --border: #2d3748;
  --text-main: #f1f5f9;
  --text-muted: #94a3b8;
  --text-inverse: #0f172a;
  --shadow-color: rgba(0, 0, 0, 0.5);

  --ocean: var(--brand-teal-light);
  --teal: var(--brand-teal-light);
}

/* ============ RESET & BASE ============ */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  font-family: var(--font-body);
  color: var(--text-main);
  background: var(--bg-body);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  transition: background var(--transition), color var(--transition);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

a {
  color: inherit;
  text-decoration: none;
  transition: all var(--transition);
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
  width: 100%;
}

/* ============ ANNOUNCEMENT BAR ============ */
.announcement-bar {
  background: linear-gradient(90deg, var(--brand-navy) 0%, var(--brand-ocean) 50%, var(--brand-navy) 100%);
  color: white;
  text-align: center;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.5px;
  z-index: 1100;
}

/* ============ NAVIGATION ============ */
.site-header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: var(--bg-nav);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}

.nav-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 24px;
  height: 68px;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.logo-icon {
  width: 38px;
  height: 38px;
  background: linear-gradient(135deg, var(--brand-navy), var(--brand-ocean));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
}

.logo-text {
  font-family: var(--font-display);
  font-size: 17px;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 1px;
}

.logo-accent {
  color: var(--brand-teal);
}

.nav-search {
  flex: 1;
  max-width: 420px;
  position: relative;
}

.search-input {
  width: 100%;
  padding: 10px 44px 10px 16px;
  border: 1.5px solid var(--border);
  border-radius: 50px;
  font-size: 14px;
  background: var(--bg-surface);
  color: var(--text-main);
  outline: none;
}

.search-input:focus {
  border-color: var(--brand-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.12);
}

.search-btn {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-muted);
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.nav-link {
  padding: 8px 12px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-main);
  border-radius: var(--radius-sm);
}

.nav-link:hover {
  color: var(--brand-teal);
  background: var(--bg-surface);
}

.nav-icon-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  position: relative;
  font-size: 18px;
}

.nav-icon-btn:hover {
  background: var(--bg-surface);
  color: var(--brand-teal);
}

.badge {
  position: absolute;
  top: 2px;
  right: 2px;
  background: var(--brand-coral);
  color: white;
  font-size: 10px;
  font-weight: 700;
  min-width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--bg-card);
}

/* ============ BUTTONS ============ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 22px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  border-radius: var(--radius);
  border: 2px solid transparent;
  cursor: pointer;
  transition: all var(--transition);
  white-space: nowrap;
}

.btn-primary {
  background: linear-gradient(135deg, var(--brand-navy), var(--brand-ocean));
  color: white;
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(30, 77, 140, 0.3);
}

.btn-teal {
  background: var(--brand-teal);
  color: white;
}

.btn-teal:hover {
  background: var(--brand-teal-light);
  color: var(--brand-navy);
}

.btn-outline {
  border-color: var(--border);
  background: transparent;
  color: var(--text-main);
}

.btn-outline:hover {
  border-color: var(--brand-teal);
  color: var(--brand-teal);
}

.btn-whatsapp {
  background: #25D366;
  color: white;
}

.btn-whatsapp:hover {
  background: #22c55e;
  box-shadow: 0 6px 20px rgba(37, 211, 102, 0.3);
}

.btn-sm { padding: 6px 14px; font-size: 12px; }
.btn-lg { padding: 14px 32px; font-size: 16px; }
.btn-block { width: 100%; }

/* ============ PRODUCT CARDS ============ */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
}

.product-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: all var(--transition);
}

.product-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.product-card-image {
  aspect-ratio: 4/3;
  overflow: hidden;
  position: relative;
  background: var(--bg-surface);
}

.product-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.product-card:hover .product-card-image img {
  transform: scale(1.05);
}

.product-card-body {
  padding: 16px;
}

.product-name {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--text-main);
}

.product-price {
  font-size: 18px;
  font-weight: 700;
  color: var(--brand-ocean);
}

[data-theme="dark"] .product-price { color: var(--brand-teal-light); }

/* ============ PRODUCT DETAIL ============ */
.product-detail-container {
  max-width: 1400px;
  margin: 40px auto;
  padding: 0 24px;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 24px;
}

.breadcrumb a {
  color: var(--text-muted);
}

.breadcrumb a:hover {
  color: var(--brand-teal);
}

.product-detail-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 48px;
  margin-bottom: 60px;
}

@media (max-width: 992px) {
  .product-detail-grid {
    grid-template-columns: 1fr;
  }
}

.product-gallery {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.gallery-main {
  position: relative;
  min-height: 400px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: zoom-in;
  overflow: hidden;
}

.gallery-main-img {
  max-width: 100%;
  max-height: 600px;
  object-fit: contain;
  transition: transform 0.3s ease;
}

.gallery-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  color: var(--text-muted);
}

.gallery-zoom-hint {
  position: absolute;
  bottom: 16px;
  right: 16px;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 11px;
  backdrop-filter: blur(4px);
  pointer-events: none;
}

.gallery-thumbs {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding: 8px 0;
  scrollbar-width: thin;
}

.gallery-thumb {
  width: 80px;
  height: 80px;
  border: 2px solid transparent;
  border-radius: var(--radius-sm);
  cursor: pointer;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--bg-surface);
  transition: all var(--transition);
}

.gallery-thumb.active {
  border-color: var(--brand-teal);
  transform: scale(0.95);
}

.gallery-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-info {
  display: flex;
  flex-direction: column;
}

.product-info-header {
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}

.product-category-tag {
  font-size: 12px;
  font-weight: 700;
  color: var(--brand-teal);
  text-transform: uppercase;
  letter-spacing: 1.2px;
}

.product-badges-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.badge-featured, .badge-condition, .badge-status {
  padding: 4px 12px;
  border-radius: 50px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
}

.badge-featured { background: var(--gold); color: white; }
.badge-status-available { background: var(--success); color: white; }
.badge-status-sold { background: var(--error); color: white; }
.badge-status-pending { background: var(--warning); color: white; }
.badge-condition.badge-new { background: var(--brand-teal); color: white; }
.badge-condition.badge-used { background: var(--text-muted); color: white; }
.badge-condition.badge-refurbished { background: var(--brand-ocean); color: white; }

.product-detail-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 12px;
  line-height: 1.1;
}

.product-rating-detail {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.product-rating-detail .stars {
  --percent: calc(var(--rating) / 5 * 100%);
  display: inline-block;
  font-size: 18px;
  background: linear-gradient(90deg, var(--gold) var(--percent), var(--border) var(--percent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 2px;
}

.rating-score {
  font-weight: 700;
  color: var(--text-main);
}

.rating-count, .rating-link {
  font-size: 14px;
  color: var(--text-muted);
}

.rating-link:hover {
  color: var(--brand-teal);
  text-decoration: underline;
}

.product-price-detail {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin: 24px 0;
  display: flex;
  align-items: baseline;
  gap: 12px;
}

.price-main {
  font-size: 36px;
  font-weight: 800;
  color: var(--brand-ocean);
  line-height: 1;
}

.price-contact {
  font-size: 24px;
  font-weight: 700;
  color: var(--brand-teal);
}

[data-theme="dark"] .price-main { color: var(--brand-teal-light); }

.product-description {
  font-size: 16px;
  line-height: 1.8;
  color: var(--text-main);
  margin-bottom: 32px;
}

.product-specs {
  margin-bottom: 32px;
}

.specs-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
  border-top: 1px solid var(--border);
  padding-top: 16px;
}

.spec-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px dotted var(--border);
}

.spec-key {
  font-weight: 600;
  color: var(--text-muted);
  font-size: 14px;
}

.spec-value {
  font-weight: 500;
  color: var(--text-main);
  font-size: 14px;
}

.product-location {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: var(--text-muted);
  margin-bottom: 24px;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 32px;
}

.product-tags .tag {
  background: var(--bg-surface);
  border: 1px solid var(--border);
  padding: 4px 12px;
  border-radius: 4px;
  font-size: 12px;
  color: var(--text-muted);
}

.product-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 16px;
}

.product-actions .btn:last-child:nth-child(odd) {
  grid-column: span 2;
}

.btn-contact {
  flex: 1;
}

.product-secondary-actions {
  display: flex;
  gap: 12px;
  margin-bottom: 32px;
}

.secondary-action-btn {
  flex: 1;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  padding: 10px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  cursor: pointer;
  transition: all var(--transition);
}

.secondary-action-btn:hover {
  background: var(--bg-card);
  border-color: var(--brand-teal);
  color: var(--brand-teal);
}

.product-meta-detail {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  padding: 20px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  font-size: 14px;
}

/* Inquiry Section */
.inquiry-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 32px;
  margin-bottom: 48px;
}

.inquiry-form {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

@media (max-width: 600px) {
  .form-grid { grid-template-columns: 1fr; }
}

/* Ratings & Reviews */
.ratings-section {
  padding: 60px 0;
  border-top: 1px solid var(--border);
}

.ratings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
  flex-wrap: wrap;
  gap: 16px;
}

.ratings-summary {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 48px;
  align-items: center;
  background: var(--bg-surface);
  padding: 40px;
  border-radius: var(--radius-lg);
  margin-bottom: 48px;
}

.rating-login-prompt {
  background: var(--bg-surface);
  padding: 24px;
  border-radius: var(--radius);
  text-align: center;
  border: 1px dashed var(--border);
  margin-bottom: 32px;
}

.rating-login-prompt a {
  color: var(--brand-teal);
  font-weight: 600;
  text-decoration: underline;
}

@media (max-width: 850px) {
  .ratings-summary {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 32px;
  }
}

.rating-big {
  font-size: 64px;
  font-weight: 800;
  color: var(--text-main);
  line-height: 1;
}

.rating-big-info {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.rating-distribution {
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}

.rating-bar {
  display: flex;
  align-items: center;
  gap: 16px;
}

.rating-bar-label {
  width: 20px;
  font-weight: 700;
  font-size: 14px;
}

.rating-bar-track {
  flex: 1;
  height: 8px;
  background: var(--border);
  border-radius: 4px;
  overflow: hidden;
}

.rating-bar-fill {
  height: 100%;
  background: var(--gold);
}

.rating-bar-count {
  width: 30px;
  font-size: 13px;
  color: var(--text-muted);
}

.rate-product {
  padding: 24px;
  border: 2px dashed var(--border);
  border-radius: var(--radius);
  text-align: center;
}

.star-rating-input {
  display: flex;
  flex-direction: row-reverse;
  justify-content: center;
  gap: 8px;
  margin: 16px 0;
}

.star-rating-input input { display: none; }
.star-rating-input label {
  font-size: 32px;
  color: var(--border);
  cursor: pointer;
  transition: color var(--transition);
}

.star-rating-input label:hover,
.star-rating-input label:hover ~ label,
.star-rating-input input:checked ~ label {
  color: var(--gold);
}

.reviews-list {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.review-item {
  padding: 24px;
  border-bottom: 1px solid var(--border);
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.reviewer-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.reviewer-name {
  font-weight: 700;
  font-size: 16px;
}

.review-date {
  font-size: 13px;
  color: var(--text-muted);
}

.review-text {
  font-size: 15px;
  line-height: 1.6;
  color: var(--text-main);
}

.related-products {
  padding: 60px 0;
  border-top: 1px solid var(--border);
}

/* Zoom Modal */
.zoom-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.9);
  z-index: 2000;
  padding: 40px;
  cursor: zoom-out;
}

.zoom-modal.active {
  display: flex;
  align-items: center;
  justify-content: center;
}

.zoom-modal img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.zoom-modal button {
  position: absolute;
  top: 20px;
  right: 20px;
  background: none;
  border: none;
  color: white;
  font-size: 32px;
  cursor: pointer;
  z-index: 2100;
}

/* ============ FOOTER (ALWAYS DARK) ============ */
.site-footer {
  background: var(--brand-navy) !important;
  color: white !important;
  padding: 64px 0 24px;
  margin-top: auto;
}

.footer-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 40px;
  margin-bottom: 48px;
}

@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 480px) {
  .footer-grid { grid-template-columns: 1fr; }
}

.footer-logo .logo-text {
  color: white !important;
}

.footer-col h4 {
  color: white !important;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 24px;
}

.footer-col ul {
  list-style: none;
}

.footer-col ul li {
  margin-bottom: 12px;
}

.footer-col ul li a {
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
}

.footer-col ul li a:hover {
  color: var(--brand-teal-light);
}

.footer-social {
  display: flex;
  gap: 12px;
}

.footer-social .social-btn {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.1);
  color: white !important;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition);
}

.footer-social .social-btn:hover {
  background: var(--brand-teal);
  transform: translateY(-3px);
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5) !important;
}

/* ============ OTHER SECTIONS ============ */
.section { padding: 60px 0; }
.section-title {
  font-family: var(--font-display);
  font-size: 28px;
  margin-bottom: 32px;
  text-align: center;
}

.form-group { margin-bottom: 20px; }
.form-label { display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; }
.form-input, .form-select, .form-textarea {
  width: 100%;
  padding: 12px 16px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-card);
  color: var(--text-main);
  outline: none;
}

.form-input:focus { border-color: var(--brand-teal); }

.alert {
  padding: 16px;
  border-radius: var(--radius);
  margin-bottom: 24px;
  font-weight: 500;
}
.alert-success { background: rgba(5, 150, 105, 0.1); color: var(--success); border: 1px solid var(--success); }
.alert-error { background: rgba(220, 38, 38, 0.1); color: var(--error); border: 1px solid var(--error); }

/* Utility */
.text-muted { color: var(--text-muted); }
.flex-center { display: flex; align-items: center; justify-content: center; }
.mt-4 { margin-top: 16px; }
.mb-4 { margin-bottom: 16px; }
